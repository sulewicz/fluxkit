# UI commands
# ---------------------------------------------------------------------------

fluxkit_write_runtime_env() {
  local port="$1" pid="$2" backend="${3:-cli}" container="${4:-}"
  local root canonical runtime_file
  root="$(fluxkit_repo_root)"
  canonical="$(fluxkit_canonical_path "$root")"
  runtime_file="$(fluxkit_runtime_env)"
  mkdir -p "$(dirname "$runtime_file")"
  cat >"$runtime_file" <<EOF
FLUX_SERVER=http://127.0.0.1:${port}
FLUX_UI_PORT=${port}
FLUX_UI_PID=${pid}
FLUX_UI_BACKEND=${backend}
FLUX_UI_CONTAINER=${container}
FLUX_REPO_ROOT=${canonical}
EOF
}

fluxkit_ui_process_valid() {
  local repo_root="$1"
  local backend="${FLUX_UI_BACKEND:-cli}"
  if [[ "$backend" == "docker" ]]; then
    local expected
    expected="$(fluxkit_ui_container_name)"
    [[ "${FLUX_UI_CONTAINER:-}" == "$expected" ]] && fluxkit_docker_container_running "$expected"
    return
  fi
  fluxkit_pid_alive "${FLUX_UI_PID:-}" && fluxkit_is_flux_serve_process "${FLUX_UI_PID}" "$repo_root"
}

fluxkit_ui_running_info() {
  local runtime_file repo_root
  local running=0 url="" pid="" valid=0 port="" preferred fallback=0 backend=""

  preferred="$(fluxkit_preferred_port)"
  runtime_file="$(fluxkit_runtime_env)"
  repo_root="$(fluxkit_repo_root)"

  if [[ -f "$runtime_file" ]] && fluxkit_runtime_matches_repo "$runtime_file" "$repo_root"; then
    FLUX_UI_PID="$(fluxkit_runtime_get "$runtime_file" FLUX_UI_PID)"
    FLUX_UI_PORT="$(fluxkit_runtime_get "$runtime_file" FLUX_UI_PORT)"
    FLUX_SERVER="$(fluxkit_runtime_get "$runtime_file" FLUX_SERVER)"
    FLUX_UI_BACKEND="$(fluxkit_runtime_get "$runtime_file" FLUX_UI_BACKEND)"
    FLUX_UI_CONTAINER="$(fluxkit_runtime_get "$runtime_file" FLUX_UI_CONTAINER)"
    pid="${FLUX_UI_PID:-}"
    port="${FLUX_UI_PORT:-}"
    url="${FLUX_SERVER:-}"
    backend="${FLUX_UI_BACKEND:-cli}"
    if fluxkit_ui_process_valid "$repo_root"; then
      running=1
      valid=1
    fi
  fi

  if [[ "$port" != "$preferred" && -n "$port" ]]; then
    fallback=1
  fi

  printf 'running=%q\nurl=%q\npid=%q\nvalid=%q\npreferred=%q\nport=%q\nfallback=%q\nbackend=%q\n' \
    "$running" "$url" "$pid" "$valid" "$preferred" "$port" "$fallback" "$backend"
}

fluxkit_start_ui_docker() {
  local port="$1" repo_root="$2" flux_dir="$3" data_file="$4"
  local docker_cmd container_name log_file container_id
  local state_mode external_scope branch_name canonical_root
  local volume_args=()

  docker_cmd="$(fluxkit_find_docker)"
  container_name="$(fluxkit_ui_container_name)"
  log_file="$(fluxkit_ui_log_file)"
  state_mode="$(fluxkit_state_mode)"
  external_scope=""
  if [[ "$state_mode" == "external" ]]; then
    external_scope="$(fluxkit_external_scope)"
  fi
  branch_name="$(fluxkit_branch_name)"
  canonical_root="$(fluxkit_canonical_path "$repo_root")"
  mkdir -p "$(dirname "$log_file")"

  if ! fluxkit_docker_daemon_ready; then
    fluxkit_die "Docker daemon not reachable (check: docker info)"
  fi

  "$docker_cmd" rm -f "$container_name" >/dev/null 2>&1 || true

  : >"$log_file"
  volume_args=(-v "${repo_root}:${repo_root}")
  if ! fluxkit_path_is_inside "$flux_dir" "$repo_root"; then
    volume_args+=(-v "${flux_dir}:${flux_dir}")
  fi

  container_id="$("$docker_cmd" run -d \
    --name "$container_name" \
    --user "$(id -u):$(id -g)" \
    --label "fluxkit.managed=true" \
    --label "fluxkit.repo_root=${canonical_root}" \
    --label "fluxkit.flux_dir=${flux_dir}" \
    --label "fluxkit.data_file=${data_file}" \
    --label "fluxkit.state_mode=${state_mode}" \
    --label "fluxkit.external_scope=${external_scope}" \
    --label "fluxkit.branch=${branch_name}" \
    -p "127.0.0.1:${port}:${port}" \
    "${volume_args[@]}" \
    -e "FLUX_DIR=${flux_dir}" \
    -e "FLUX_DATA=${data_file}" \
    -e "PORT=${port}" \
    "$FLUX_DOCKER_IMAGE" \
    bun /app/packages/server/dist/index.js 2>>"$log_file")" || {
    fluxkit_die "failed to start Flux UI via Docker (see $log_file)"
  }

  local i
  for i in $(seq 1 30); do
    if fluxkit_server_healthy "http://127.0.0.1:${port}"; then
      fluxkit_write_runtime_env "$port" "" "docker" "$container_name"
      return 0
    fi
    sleep 1
  done

  "$docker_cmd" logs "$container_id" >>"$log_file" 2>&1 || \
    "$docker_cmd" logs "$container_name" >>"$log_file" 2>&1 || true
  "$docker_cmd" rm -f "$container_name" >/dev/null 2>&1 || true
  fluxkit_die "Flux UI container failed to become healthy (see $log_file)"
}

fluxkit_cmd_ui_up() {
  local preferred port log_file pid flux_cmd info running backend docker_cmd
  [[ $# -eq 0 ]] || fluxkit_die "ui up does not accept options; run it inside the repo/branch to start"
  fluxkit_require_git
  preferred="$(fluxkit_preferred_port)"

  info="$(fluxkit_ui_running_info)"
  eval "$info"
  if [[ "$running" == "1" && "$valid" == "1" ]]; then
    fluxkit_info "Flux UI already running at $url (${backend:-cli})"
    exit 0
  fi

  port="$(fluxkit_find_ui_port "$preferred")"
  if [[ "$port" != "$preferred" ]]; then
    fluxkit_warn "preferred port $preferred in use; using fallback port $port"
  fi

  local data_file flux_dir repo_root
  data_file="$(fluxkit_data_file)"
  flux_dir="$(fluxkit_flux_dir)"
  repo_root="$(fluxkit_repo_root)"
  [[ -f "$data_file" ]] || fluxkit_die "missing $data_file — run: fluxkit init"

  backend="${FLUXKIT_UI_BACKEND:-docker}"
  if [[ "$backend" == "docker" ]]; then
    fluxkit_docker_daemon_ready || fluxkit_die "Docker required for Kanban UI (image: $FLUX_DOCKER_IMAGE) — check: docker info"
  elif [[ "$backend" != "cli" ]]; then
    fluxkit_die "unknown FLUXKIT_UI_BACKEND: $backend (use docker or cli)"
  fi

  log_file="$(fluxkit_ui_log_file)"
  mkdir -p "$(dirname "$log_file")"

  if [[ "$backend" == "docker" ]]; then
    fluxkit_start_ui_docker "$port" "$repo_root" "$flux_dir" "$data_file"
    fluxkit_info "Flux UI started at http://127.0.0.1:${port} (docker: $(fluxkit_ui_container_name), state: $(fluxkit_state_desc))"
  else
    fluxkit_warn "API-only mode (no Kanban web UI); set FLUXKIT_UI_BACKEND=docker for the board"
    flux_cmd="$(fluxkit_flux_cli_runnable)" || fluxkit_die "cli backend requires flux + bun on PATH"
    (
      cd "$repo_root"
      exec "$flux_cmd" serve -p "$port" --data "$data_file"
    ) >"$log_file" 2>&1 &
    pid=$!
    sleep 1
    if ! fluxkit_pid_alive "$pid"; then
      fluxkit_die "failed to start Flux API server (see $log_file)"
    fi
    fluxkit_write_runtime_env "$port" "$pid" "cli" ""
    fluxkit_info "Flux API started at http://127.0.0.1:${port} (pid $pid, state: $(fluxkit_state_desc), no web UI)"
  fi

  if [[ "$port" != "$preferred" ]]; then
    fluxkit_info "note: using fallback port (preferred was $preferred)"
  fi
}

fluxkit_cmd_ui_down() {
  local runtime_file repo_root pid backend container docker_cmd expected all=0 target="" target_set=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all|-a)
        all=1
        ;;
      --target|-t)
        [[ $# -ge 2 ]] || fluxkit_die "--target requires a CONTAINER value from 'fluxkit ui list'"
        target="$2"
        target_set=1
        shift
        ;;
      --target=*)
        target="${1#--target=}"
        [[ -n "$target" ]] || fluxkit_die "--target requires a CONTAINER value from 'fluxkit ui list'"
        target_set=1
        ;;
      -t=*)
        target="${1#-t=}"
        [[ -n "$target" ]] || fluxkit_die "--target requires a CONTAINER value from 'fluxkit ui list'"
        target_set=1
        ;;
      *)
        fluxkit_die "unknown ui down option: $1 (use --all, -a, --target, -t, or no options)"
        ;;
    esac
    shift
  done

  if (( all && target_set )); then
    fluxkit_die "use either --all or --target, not both"
  fi

  if (( all )); then
    fluxkit_cmd_ui_down_all
    return 0
  fi

  if (( target_set )) && ! fluxkit_is_fluxkit_container_name "$target" && ! fluxkit_is_docker_container_id "$target"; then
    fluxkit_die "invalid UI target: $target (use a CONTAINER value from 'fluxkit ui list')"
  fi

  if (( target_set )); then
    fluxkit_stop_docker_ui_container "$target"
    return 0
  fi

  fluxkit_require_git
  runtime_file="$(fluxkit_runtime_env)"
  repo_root="$(fluxkit_repo_root)"

  [[ -f "$runtime_file" ]] || {
    fluxkit_info "no runtime.env — UI is not running (or was not started by fluxkit)"
    exit 0
  }

  if ! fluxkit_runtime_matches_repo "$runtime_file" "$repo_root"; then
    fluxkit_die "runtime.env belongs to a different repository; refusing to stop"
  fi

  FLUX_UI_BACKEND="$(fluxkit_runtime_get "$runtime_file" FLUX_UI_BACKEND)"
  FLUX_UI_CONTAINER="$(fluxkit_runtime_get "$runtime_file" FLUX_UI_CONTAINER)"
  FLUX_UI_PID="$(fluxkit_runtime_get "$runtime_file" FLUX_UI_PID)"
  backend="${FLUX_UI_BACKEND:-cli}"

  if [[ "$backend" == "docker" ]]; then
    container="${FLUX_UI_CONTAINER:-}"
    expected="$(fluxkit_ui_container_name)"
    [[ -n "$container" ]] || fluxkit_die "runtime.env missing FLUX_UI_CONTAINER"
    [[ "$container" == "$expected" ]] || fluxkit_die "container $container does not match this repo; refusing to stop"
    docker_cmd="$(fluxkit_find_docker 2>/dev/null || fluxkit_die "docker not available")"
    if fluxkit_docker_container_running "$container"; then
      fluxkit_docker_container_managed "$container" || fluxkit_die "container $container is not managed by Fluxkit"
      "$docker_cmd" rm -f "$container" >/dev/null || fluxkit_die "failed to stop container $container"
      fluxkit_info "stopped Flux UI (docker: $container, state: $(fluxkit_state_desc))"
    else
      fluxkit_info "recorded container $container is not running"
    fi
    rm -f "$runtime_file"
    return 0
  fi

  pid="${FLUX_UI_PID:-}"
  if [[ -z "$pid" ]]; then
    fluxkit_die "runtime.env missing FLUX_UI_PID"
  fi

  if ! fluxkit_pid_alive "$pid"; then
    fluxkit_info "recorded PID $pid is not running"
    rm -f "$runtime_file"
    exit 0
  fi

  if ! fluxkit_is_flux_serve_process "$pid" "$repo_root"; then
    fluxkit_die "PID $pid does not look like this repo's Flux serve process; refusing to kill"
  fi

  kill "$pid" 2>/dev/null || fluxkit_die "failed to stop PID $pid"
  fluxkit_info "stopped Flux UI (pid $pid, state: $(fluxkit_state_desc))"
  rm -f "$runtime_file"
}

fluxkit_cmd_ui_list() {
  local docker_cmd rows
  [[ $# -eq 0 ]] || fluxkit_die "ui list does not accept options"
  docker_cmd="$(fluxkit_find_docker 2>/dev/null || fluxkit_die "docker not available")"
  fluxkit_docker_daemon_ready || fluxkit_die "Docker daemon not reachable (check: docker info)"

  rows="$(fluxkit_docker_fluxkit_container_rows "$docker_cmd")"
  if [[ -z "$rows" ]]; then
    fluxkit_info "no running Fluxkit UI containers"
    return 0
  fi

  printf 'CONTAINER\tNAME\tPORTS\tMODE\tSCOPE\tBRANCH\tREPO\tDATA\n'
  printf '%s\n' "$rows"
}

fluxkit_cmd_ui_down_all() {
  local docker_cmd targets target stopped=0
  docker_cmd="$(fluxkit_find_docker 2>/dev/null || fluxkit_die "docker not available")"
  fluxkit_docker_daemon_ready || fluxkit_die "Docker daemon not reachable (check: docker info)"

  targets="$(fluxkit_docker_fluxkit_container_targets "$docker_cmd")"
  if [[ -z "$targets" ]]; then
    fluxkit_info "no running Fluxkit UI containers"
    return 0
  fi

  while IFS= read -r target; do
    [[ -n "$target" ]] || continue
    "$docker_cmd" rm -f "$target" >/dev/null || fluxkit_die "failed to stop container $target"
    fluxkit_info "stopped Flux UI (docker: $target)"
    stopped=$((stopped + 1))
  done <<< "$targets"

  fluxkit_info "stopped $stopped Fluxkit UI container(s)"
}

fluxkit_cmd_ui_status() {
  local info
  fluxkit_require_git
  info="$(fluxkit_ui_running_info)"
  eval "$info"

  echo "UI status: $([[ "$running" == "1" ]] && echo running || echo stopped)"
  echo "Backend: ${backend:-n/a}"
  echo "URL: ${url:-n/a}"
  echo "PID: ${pid:-n/a}"
  echo "Process valid: $([[ "$valid" == "1" ]] && echo yes || echo no)"
  echo "Preferred port: $preferred"
  echo "Actual port: ${port:-n/a}"
  echo "Fallback used: $([[ "$fallback" == "1" ]] && echo yes || echo no)"
}

fluxkit_cmd_port() {
  local info
  fluxkit_require_git
  info="$(fluxkit_ui_running_info)"
  eval "$info"
  echo "repo root: $(fluxkit_repo_root)"
  echo "preferred port: $preferred"
  echo "running port: ${port:-none}"
  echo "URL: ${url:-none}"
}

# ---------------------------------------------------------------------------
# Doctor
# ---------------------------------------------------------------------------

fluxkit_doctor_check() {
  local label="$1" ok="$2" fix="${3:-}"
  if [[ "$ok" == "ok" ]]; then
    printf '  [ok] %s\n' "$label"
  elif [[ "$ok" == "warn" ]]; then
    printf '  [warn] %s\n' "$label"
    [[ -n "$fix" ]] && printf '         fix: %s\n' "$fix"
  else
    printf '  [fail] %s\n' "$label"
    [[ -n "$fix" ]] && printf '         fix: %s\n' "$fix"
  fi
}

fluxkit_cmd_doctor() {
  local root flux_dir mode scope issues=0
  root="$(fluxkit_repo_root 2>/dev/null || true)"
  if [[ -z "$root" ]]; then
    fluxkit_doctor_check "inside a git repository" "fail" "run from inside a git repo"
    exit 1
  fi
  flux_dir="$(fluxkit_flux_dir)"
  mode="$(fluxkit_state_mode)"
  scope=""
  if [[ "$mode" == "external" ]]; then
    scope="$(fluxkit_external_scope)"
  fi

  echo "fluxkit doctor"
  echo "state mode: $mode"
  [[ -n "$scope" ]] && echo "external scope: $scope"
  echo ""

  fluxkit_doctor_check "inside a git repository" "ok"

  if [[ -f "$(fluxkit_data_file)" ]]; then
    fluxkit_doctor_check "Flux data exists ($(fluxkit_data_file))" "ok"
  else
    if [[ "$mode" == "external" ]]; then
      fluxkit_doctor_check "Flux data exists ($(fluxkit_data_file))" "fail" "fluxkit init --external"
    else
      fluxkit_doctor_check "Flux data exists ($(fluxkit_data_file))" "fail" "fluxkit init"
    fi
    issues=$((issues + 1))
  fi

  if [[ -f "$flux_dir/config.json" ]]; then
    fluxkit_doctor_check "Flux config exists ($flux_dir/config.json)" "ok"
  else
    if [[ "$mode" == "external" ]]; then
      fluxkit_doctor_check "Flux config exists ($flux_dir/config.json)" "fail" "fluxkit init --external"
    else
      fluxkit_doctor_check "Flux config exists ($flux_dir/config.json)" "fail" "fluxkit init"
    fi
    issues=$((issues + 1))
  fi

  if [[ -f "$flux_dir/project.json" ]]; then
    fluxkit_doctor_check "Flux project hint exists ($flux_dir/project.json)" "ok"
  else
    if [[ "$mode" == "external" ]]; then
      fluxkit_doctor_check "Flux project hint exists ($flux_dir/project.json)" "fail" "fluxkit init --external"
    else
      fluxkit_doctor_check "Flux project hint exists ($flux_dir/project.json)" "fail" "fluxkit init"
    fi
    issues=$((issues + 1))
  fi

  if [[ "$mode" == "external" ]]; then
    if fluxkit_global_cursor_configured; then
      fluxkit_doctor_check "$(fluxkit_global_cursor_mcp_file) contains fluxkit mcp" "ok"
    else
      fluxkit_doctor_check "$(fluxkit_global_cursor_mcp_file) contains fluxkit mcp" "fail" "fluxkit init --external"
      issues=$((issues + 1))
    fi

    if fluxkit_global_codex_configured; then
      fluxkit_doctor_check "$(fluxkit_global_codex_config_file) contains fluxkit mcp" "ok"
    else
      fluxkit_doctor_check "$(fluxkit_global_codex_config_file) contains fluxkit mcp" "fail" "fluxkit init --external"
      issues=$((issues + 1))
    fi

    if fluxkit_global_agents_block_valid "$(fluxkit_home_agents_file)" 2>/dev/null; then
      fluxkit_doctor_check "$(fluxkit_home_agents_file) contains Fluxkit global guidance" "ok"
    else
      fluxkit_doctor_check "$(fluxkit_home_agents_file) contains Fluxkit global guidance" "fail" "fluxkit init --external"
      issues=$((issues + 1))
    fi
  else
    if [[ -f "$root/.cursor/mcp.json" ]] && grep -q '.flux/bin/mcp' "$root/.cursor/mcp.json" 2>/dev/null; then
      fluxkit_doctor_check ".cursor/mcp.json points to .flux/bin/mcp" "ok"
    else
      fluxkit_doctor_check ".cursor/mcp.json points to .flux/bin/mcp" "fail" "fluxkit init"
      issues=$((issues + 1))
    fi

    if [[ -f "$root/.codex/config.toml" ]] && grep -q '\[mcp_servers\.flux\]' "$root/.codex/config.toml" 2>/dev/null; then
      fluxkit_doctor_check ".codex/config.toml contains Flux MCP server" "ok"
    else
      fluxkit_doctor_check ".codex/config.toml contains Flux MCP server" "fail" "fluxkit init"
      issues=$((issues + 1))
    fi

    if [[ -f "$root/AGENTS.md" ]]; then
      fluxkit_doctor_check "AGENTS.md exists" "ok"
    else
      fluxkit_doctor_check "AGENTS.md exists" "fail" "fluxkit init"
      issues=$((issues + 1))
    fi

    if fluxkit_agents_block_valid "$root/AGENTS.md" 2>/dev/null; then
      fluxkit_doctor_check "AGENTS.md contains valid Fluxkit managed block" "ok"
    else
      fluxkit_doctor_check "AGENTS.md contains valid Fluxkit managed block" "fail" "fluxkit init (check marker pairs)"
      issues=$((issues + 1))
    fi
  fi

  if fluxkit_docker_daemon_ready; then
    fluxkit_doctor_check "Docker ready for Kanban UI ($FLUX_DOCKER_IMAGE)" "ok"
  else
    fluxkit_doctor_check "Docker ready for Kanban UI" "fail" "check: docker info (required for fluxkit ui up)"
    issues=$((issues + 1))
  fi

  local info preferred port url running backend
  info="$(fluxkit_ui_running_info)"
  eval "$info"
  if [[ "$running" == "1" ]]; then
    if [[ "${backend:-}" == "cli" ]]; then
      fluxkit_doctor_check "UI running on port ${port} ($url)" "warn" "API-only backend — fluxkit ui down && fluxkit ui up for Kanban UI"
    else
      fluxkit_doctor_check "Kanban UI running on port ${port} ($url)" "ok"
    fi
  else
    fluxkit_doctor_check "UI preferred port ${preferred} (not running)" "warn" "fluxkit ui up"
  fi

  if [[ "$mode" == "external" ]]; then
    fluxkit_doctor_check "MCP command is fluxkit mcp" "ok"
  elif [[ -x "$flux_dir/bin/mcp" ]]; then
    fluxkit_doctor_check "MCP launcher is executable" "ok"
  else
    fluxkit_doctor_check "MCP launcher is executable" "fail" "fluxkit init && chmod +x .flux/bin/mcp"
    issues=$((issues + 1))
  fi

  if [[ "$mode" == "external" ]]; then
    fluxkit_doctor_check "runtime state is outside the repository ($(fluxkit_runtime_env))" "ok"
  else
    if fluxkit_gitignore_ignores_runtime "$root"; then
      fluxkit_doctor_check ".flux/runtime.env is gitignored" "ok"
    else
      fluxkit_doctor_check ".flux/runtime.env is gitignored" "fail" "fluxkit init"
      issues=$((issues + 1))
    fi
  fi

  echo ""
  if (( issues == 0 )); then
    echo "All checks passed."
  else
    echo "$issues issue(s) found."
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

fluxkit_help_row() {
  printf '  %-48s  %s\n' "$1" "$2"
}

fluxkit_help_arg_row() {
  printf '  %-14s  %s\n' "$1" "$2"
}

fluxkit_cmd_help() {
  cat <<EOF
fluxkit $FLUXKIT_VERSION — repo-local Flux setup for git projects

Usage:
EOF
  fluxkit_help_row "fluxkit init" "Initialize repo-local .flux/ and editor integrations"
  fluxkit_help_row "fluxkit init [-l | --local]" "Force repo-local .flux creation when external state exists"
  fluxkit_help_row "fluxkit init [-e | --external] [repo|branch]" "Initialize external Flux state (default: repo)"
  fluxkit_help_row "fluxkit ui up" "Start Flux UI/API for the current repo/branch"
  fluxkit_help_row "fluxkit ui down" "Stop the current repo/branch UI"
  fluxkit_help_row "fluxkit ui down [-t | --target] CONTAINER" "Stop one listed Docker UI container"
  fluxkit_help_row "fluxkit ui down [-a | --all]" "Stop all running Fluxkit Docker UI containers"
  fluxkit_help_row "fluxkit ui status" "Show UI runtime status"
  fluxkit_help_row "fluxkit ui list" "List running Fluxkit Docker UI containers"
  fluxkit_help_row "fluxkit port" "Show preferred and running ports"
  fluxkit_help_row "fluxkit mcp" "Run MCP server for the current repo/branch"
  fluxkit_help_row "fluxkit configured" "Report whether Fluxkit is configured for this repo"
  fluxkit_help_row "fluxkit doctor" "Verify setup and report fixes"
  fluxkit_help_row "fluxkit help" "Show this help"
  cat <<EOF

Arguments:
EOF
  fluxkit_help_arg_row "CONTAINER" "ID from the CONTAINER column in 'fluxkit ui list'"
  cat <<EOF

Environment:
  FLUXKIT_PORT_BASE         Base port for hash-based assignment (default: 42000)
  FLUXKIT_PORT_SPAN         Port range span (default: 1000)
  FLUXKIT_STATE_MODE        Force state mode: local or external
  FLUXKIT_EXTERNAL_SCOPE    Force external scope: branch or repo
  FLUXKIT_FLUX_CMD          Override flux CLI path (for testing)
  FLUXKIT_DOCKER_CMD        Override docker path (for testing)
  FLUXKIT_UI_BACKEND        UI backend: docker (default, Kanban UI) or cli (API only)

Requires: git, Docker ($FLUX_DOCKER_IMAGE) for Kanban UI; Docker also used for MCP
Docs: https://github.com/sirsjg/flux
EOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

fluxkit_main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init) fluxkit_cmd_init "$@" ;;
    ui)
      local sub="${1:-}"
      shift || true
      case "$sub" in
        up) fluxkit_cmd_ui_up "$@" ;;
        down) fluxkit_cmd_ui_down "$@" ;;
        status) fluxkit_cmd_ui_status "$@" ;;
        list) fluxkit_cmd_ui_list "$@" ;;
        *) fluxkit_die "unknown ui command: ${sub:-}(none); try: up, down, status, list" ;;
      esac
      ;;
    port) fluxkit_cmd_port "$@" ;;
    mcp) fluxkit_cmd_mcp "$@" ;;
    configured) fluxkit_cmd_configured "$@" ;;
    doctor) fluxkit_cmd_doctor "$@" ;;
    help|--help|-h) fluxkit_cmd_help "$@" ;;
    *)
      fluxkit_die "unknown command: $cmd (try: fluxkit help)"
      ;;
  esac
}

if [[ "${FLUXKIT_NO_MAIN:-}" != "1" ]] && [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  fluxkit_main "$@"
fi
