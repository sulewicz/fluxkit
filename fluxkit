}

fluxkit_global_cursor_configured() {
  local mcp_json
  mcp_json="$(fluxkit_global_cursor_mcp_file)"
  [[ -f "$mcp_json" ]] &&
    grep -q '"flux"' "$mcp_json" 2>/dev/null &&
