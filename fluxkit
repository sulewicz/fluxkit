fluxkit_discover_project_id() {
  local flux_cmd project_id
  flux_cmd="$(fluxkit_find_flux_cli 2>/dev/null || true)"
  [[ -n "$flux_cmd" ]] || return 0
  project_id="$("$flux_cmd" project list --json 2>/dev/null | sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1 || true)"
  echo "$project_id"
}

fluxkit_cmd_init() {
  local root flux_dir repo_name project_id project_id_json
  local external=0 external_scope="repo" local_force=0
  local branch_name canonical repo_id branch_id repo_name_json branch_name_json canonical_json repo_id_json branch_id_json project_name project_name_json scope_json port_strategy

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --external|-e)
        external=1
        local_force=0
        if [[ $# -ge 2 && ( "$2" == "repo" || "$2" == "branch" ) ]]; then
          external_scope="$2"
          shift
        fi
        ;;
      --external=*)
        external=1
        local_force=0
        external_scope="${1#--external=}"
        ;;
      -e=*)
        external=1
        local_force=0
        external_scope="${1#-e=}"
        ;;
      --local|-l)
        external=0
        local_force=1
        ;;
      *)
        fluxkit_die "unknown init option: $1 (use [-e | --external] [repo|branch], [-l | --local], or no options)"
        ;;
    esac
    shift
  done

  case "$external_scope" in
    repo|branch) ;;
    *) fluxkit_die "unknown init scope: $external_scope (use repo or branch)" ;;
  esac

  fluxkit_require_git

  root="$(fluxkit_repo_root)"
  repo_name="$(basename "$root")"
  branch_name="$(fluxkit_branch_name)"
  canonical="$(fluxkit_canonical_path "$root")"

  if (( external )); then
    FLUXKIT_STATE_MODE=external
    FLUXKIT_EXTERNAL_SCOPE="$external_scope"
    flux_dir="$(fluxkit_external_flux_dir)"
    repo_id="$(fluxkit_repo_id)"
    branch_id="$(fluxkit_branch_id)"
    repo_name_json="$(fluxkit_json_quote "$repo_name")"
    branch_name_json="$(fluxkit_json_quote "$branch_name")"
    canonical_json="$(fluxkit_json_quote "$canonical")"
    repo_id_json="$(fluxkit_json_quote "$repo_id")"
    branch_id_json="$(fluxkit_json_quote "$branch_id")"
    scope_json="$(fluxkit_json_quote "$external_scope")"
    if [[ "$external_scope" == "branch" ]]; then
      port_strategy="hash_repo_path_and_branch"
    else
      port_strategy="hash_repo_path"
    fi
    mkdir -p "$flux_dir"

    fluxkit_write_json_if_missing "$(fluxkit_data_file)" '{"projects":[],"epics":[],"tasks":[]}'

    fluxkit_write_json_if_missing "$flux_dir/config.json" "$(cat <<EOF
{
  "storage": "external",
  "scope": ${scope_json},
  "data": ".flux/data.json",
  "repo": {
    "name": ${repo_name_json},
    "root": ${canonical_json},
    "id": ${repo_id_json}
  },
  "branch": {
    "name": ${branch_name_json},
    "id": ${branch_id_json}
  },
  "ui": {
    "host": "127.0.0.1",
    "port_strategy": "${port_strategy}",
    "port_base": ${FLUXKIT_PORT_BASE},
    "port_span": ${FLUXKIT_PORT_SPAN}
  }
}
EOF
)"

    if [[ ! -f "$flux_dir/project.json" ]]; then
      project_name="${repo_name}:${branch_name}"
      project_name_json="$(fluxkit_json_quote "$project_name")"
      cat >"$flux_dir/project.json" <<EOF
{
  "name": ${project_name_json},
  "project_id": null,
  "repo_root": ${canonical_json},
  "branch": ${branch_name_json},
  "created_by": "fluxkit"
}
EOF
    fi

    fluxkit_write_global_integrations

    fluxkit_info "initialized external Flux state for $canonical"
    fluxkit_info "branch: $branch_name"
    fluxkit_info "data: $(fluxkit_data_file)"
    fluxkit_info "global MCP: fluxkit mcp"
    return 0
  fi

  if ! (( local_force )) && ! fluxkit_local_configured && fluxkit_external_configured; then
    fluxkit_warn "external Flux state is already configured for this repo/branch"
    fluxkit_die "run 'fluxkit init --local' or 'fluxkit init -l' to create repo-local .flux state anyway"
  fi

  FLUXKIT_STATE_MODE=local
  unset FLUXKIT_EXTERNAL_SCOPE
  flux_dir="$(fluxkit_local_flux_dir)"

  mkdir -p "$flux_dir/bin" "$root/.cursor" "$root/.codex"

  fluxkit_write_json_if_missing "$(fluxkit_data_file)" '{"projects":[],"epics":[],"tasks":[]}'

  fluxkit_write_json_if_missing "$flux_dir/config.json" "$(cat <<EOF
{
  "data": ".flux/data.json",
  "ui": {
    "host": "127.0.0.1",
    "port_strategy": "hash_repo_path",
    "port_base": ${FLUXKIT_PORT_BASE},
    "port_span": ${FLUXKIT_PORT_SPAN}
  }
}
EOF
)"

  if [[ ! -f "$flux_dir/project.json" ]]; then
    project_id="$(fluxkit_discover_project_id || true)"
    if [[ -z "$project_id" ]]; then
      project_id_json="null"
    else
      project_id_json="$(fluxkit_json_quote "$project_id")"
    fi
    repo_name_json="$(fluxkit_json_quote "$repo_name")"
    cat >"$flux_dir/project.json" <<EOF
{
  "name": ${repo_name_json},
  "project_id": ${project_id_json},
  "created_by": "fluxkit"
}
EOF
  fi

  fluxkit_update_gitignore "$root"

  fluxkit_generate_mcp_launcher "$root" "$flux_dir"
  fluxkit_write_cursor_mcp "$root/.cursor"
  fluxkit_write_codex_config "$root/.codex"

  if [[ ! -f "$root/AGENTS.md" ]]; then
    : >"$root/AGENTS.md"
  fi
  fluxkit_update_agents_md "$root/AGENTS.md"

  fluxkit_info "initialized Flux in $root"
  fluxkit_info "data: $(fluxkit_data_file)"
  fluxkit_info "preferred UI port: $(fluxkit_preferred_port)"
}

