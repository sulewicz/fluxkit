set -euo pipefail

FLUXKIT_VERSION="0.1.0"
FLUX_DOCKER_IMAGE="${FLUXKIT_DOCKER_IMAGE:-sirsjg/flux-mcp:latest}"
FLUXKIT_PORT_BASE="${FLUXKIT_PORT_BASE:-42000}"
FLUXKIT_PORT_SPAN="${FLUXKIT_PORT_SPAN:-1000}"

AGENTS_BEGIN='<!-- BEGIN FLUXKIT MANAGED BLOCK -->'
AGENTS_END='<!-- END FLUXKIT MANAGED BLOCK -->'
GLOBAL_AGENTS_BEGIN='<!-- BEGIN FLUXKIT GLOBAL MANAGED BLOCK -->'
GLOBAL_AGENTS_END='<!-- END FLUXKIT GLOBAL MANAGED BLOCK -->'

# ---------------------------------------------------------------------------
# Utilities
# ---------------------------------------------------------------------------

fluxkit_die() {
  echo "fluxkit: $*" >&2
  exit 1
}

fluxkit_warn() {
  echo "fluxkit: warning: $*" >&2
}

fluxkit_info() {
  echo "fluxkit: $*"
}

fluxkit_sha256() {
  local input="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    printf '%s' "$input" | sha256sum | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then
    printf '%s' "$input" | shasum -a 256 | awk '{print $1}'
  else
    fluxkit_die "sha256sum or shasum is required"
  fi
}

fluxkit_require_git() {
  git rev-parse --show-toplevel >/dev/null 2>&1 || fluxkit_die "not inside a git repository"
}

fluxkit_repo_root() {
  fluxkit_require_git
  git rev-parse --show-toplevel
}

fluxkit_canonical_path() {
  local path="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$path"
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$path"
  else
    (
      cd "$path" 2>/dev/null || cd "$(dirname "$path")"
      pwd -P
    )
  fi
}

fluxkit_json_quote() {
  local value="$1"
  if command -v python3 >/dev/null 2>&1; then
    python3 -c 'import json, sys; print(json.dumps(sys.argv[1]))' "$value"
  else
    printf '"%s"' "$(printf '%s' "$value" | sed 's/\\/\\\\/g; s/"/\\"/g')"
  fi
}

fluxkit_home_dir() {
  [[ -n "${HOME:-}" ]] || fluxkit_die "HOME is not set"
  echo "$HOME"
}

fluxkit_xdg_data_home() {
  echo "${XDG_DATA_HOME:-$(fluxkit_home_dir)/.local/share}"
}

fluxkit_xdg_state_home() {
  echo "${XDG_STATE_HOME:-$(fluxkit_home_dir)/.local/state}"
}

fluxkit_safe_slug() {
  local value="$1" slug
  slug="$(printf '%s' "$value" | tr -c 'A-Za-z0-9._-' '-' | sed 's/--*/-/g; s/^-//; s/-$//' | cut -c1-60)"
  [[ -n "$slug" ]] || slug="item"
  echo "$slug"
}

fluxkit_repo_id() {
  local root canonical hash name
  root="$(fluxkit_repo_root)"
  canonical="$(fluxkit_canonical_path "$root")"
  hash="$(fluxkit_sha256 "$canonical")"
  name="$(fluxkit_safe_slug "$(basename "$root")")"
  echo "${name}-${hash:0:12}"
}

fluxkit_branch_name() {
  local branch
  branch="$(git branch --show-current 2>/dev/null || true)"
  if [[ -n "$branch" ]]; then
    echo "$branch"
  else
    echo "detached-$(git rev-parse --short HEAD)"
  fi
}

fluxkit_branch_id() {
  local branch hash slug
  branch="$(fluxkit_branch_name)"
  hash="$(fluxkit_sha256 "$branch")"
  slug="$(fluxkit_safe_slug "$branch")"
  echo "${slug}-${hash:0:12}"
}

fluxkit_external_repo_dir() {
  echo "$(fluxkit_xdg_data_home)/fluxkit/repos/$(fluxkit_repo_id)"
}

fluxkit_external_state_repo_dir() {
  echo "$(fluxkit_xdg_state_home)/fluxkit/repos/$(fluxkit_repo_id)"
}

fluxkit_external_scope() {
  case "${FLUXKIT_EXTERNAL_SCOPE:-}" in
    repo|branch)
      echo "$FLUXKIT_EXTERNAL_SCOPE"
      return 0
      ;;
    "")
      ;;
    *)
      fluxkit_die "unknown FLUXKIT_EXTERNAL_SCOPE: $FLUXKIT_EXTERNAL_SCOPE (use repo or branch)"
      ;;
  esac

  if [[ -f "$(fluxkit_external_repo_dir)/branches/$(fluxkit_branch_id)/.flux/config.json" ]]; then
    echo "branch"
  elif [[ -f "$(fluxkit_external_repo_dir)/.flux/config.json" ]]; then
    echo "repo"
  else
    echo "repo"
  fi
}

fluxkit_external_configured() {
  local dir
  dir="$(fluxkit_external_flux_dir)"
  [[ -f "$dir/config.json" && -f "$dir/data.json" ]]
}

fluxkit_external_flux_dir() {
  if [[ "$(fluxkit_external_scope)" == "repo" ]]; then
    echo "$(fluxkit_external_repo_dir)/.flux"
  else
    echo "$(fluxkit_external_repo_dir)/branches/$(fluxkit_branch_id)/.flux"
  fi
}

fluxkit_external_runtime_dir() {
  if [[ "$(fluxkit_external_scope)" == "repo" ]]; then
    echo "$(fluxkit_external_state_repo_dir)"
  else
    echo "$(fluxkit_external_state_repo_dir)/branches/$(fluxkit_branch_id)"
  fi
}

fluxkit_state_mode() {
  case "${FLUXKIT_STATE_MODE:-}" in
    local|external)
      echo "$FLUXKIT_STATE_MODE"
      return 0
      ;;
    "")
      ;;
    *)
      fluxkit_die "unknown FLUXKIT_STATE_MODE: $FLUXKIT_STATE_MODE (use local or external)"
      ;;
  esac

  if fluxkit_local_configured; then
    echo "local"
  elif fluxkit_external_configured; then
    echo "external"
  else
    echo "local"
  fi
}

fluxkit_flux_dir() {
  if [[ "$(fluxkit_state_mode)" == "external" ]]; then
    echo "$(fluxkit_external_flux_dir)"
  else
    echo "$(fluxkit_repo_root)/.flux"
  fi
}

fluxkit_data_file() {
  echo "$(fluxkit_flux_dir)/data.json"
}

fluxkit_local_flux_dir() {
  echo "$(fluxkit_repo_root)/.flux"
}

fluxkit_local_configured() {
  local dir
  dir="$(fluxkit_local_flux_dir)"
  [[ -f "$dir/config.json" && -f "$dir/data.json" ]]
}

fluxkit_runtime_env() {
  if [[ "$(fluxkit_state_mode)" == "external" ]]; then
    echo "$(fluxkit_external_runtime_dir)/runtime.env"
  else
    echo "$(fluxkit_flux_dir)/runtime.env"
  fi
}

fluxkit_ui_log_file() {
  if [[ "$(fluxkit_state_mode)" == "external" ]]; then
    echo "$(fluxkit_external_runtime_dir)/ui.log"
  else
    echo "$(fluxkit_flux_dir)/ui.log"
  fi
}

fluxkit_state_desc() {
  if [[ "$(fluxkit_state_mode)" == "external" ]]; then
    if [[ "$(fluxkit_external_scope)" == "branch" ]]; then
      echo "external branch $(fluxkit_branch_name)"
    else
      echo "external repo"
    fi
  else
    echo "local"
  fi
}

fluxkit_ui_seed() {
  local root canonical seed
  root="$(fluxkit_repo_root)"
  canonical="$(fluxkit_canonical_path "$root")"
  seed="$canonical"
  if [[ "$(fluxkit_state_mode)" == "external" && "$(fluxkit_external_scope)" == "branch" ]]; then
    seed="${canonical}#branch:$(fluxkit_branch_name)"
  fi
  echo "$seed"
}

fluxkit_preferred_port() {
  local hash_int hash_hex offset base span
  hash_hex="$(fluxkit_sha256 "$(fluxkit_ui_seed)")"
  hash_int="$((16#${hash_hex:0:8}))"
  base="${FLUXKIT_PORT_BASE}"
  span="${FLUXKIT_PORT_SPAN}"
  offset=$((hash_int % span))
  echo $((base + offset))
}

fluxkit_port_in_use() {
  local port="$1"
  if command -v nc >/dev/null 2>&1; then
    nc -z 127.0.0.1 "$port" >/dev/null 2>&1
    return $?
  fi
  # bash /dev/tcp fallback
  (echo >/dev/tcp/127.0.0.1/"$port") >/dev/null 2>&1
}

fluxkit_path_is_inside() {
  local path="$1" parent="$2"
  path="$(fluxkit_canonical_path "$path")"
  parent="$(fluxkit_canonical_path "$parent")"
  [[ "$path" == "$parent" || "$path" == "$parent"/* ]]
}

fluxkit_read_runtime_env() {
  local file="$1"
  [[ -f "$file" ]] || return 1
  grep -E '^[A-Z0-9_]+=' "$file" >/dev/null 2>&1
}

fluxkit_runtime_get() {
  local file="$1" key="$2" line
  [[ -f "$file" ]] || return 0
  line="$(grep -E "^${key}=" "$file" 2>/dev/null | head -1 || true)"
  printf '%s' "${line#*=}"
}

fluxkit_process_cmdline() {
  local pid="$1"
  if [[ -r "/proc/$pid/cmdline" ]]; then
    tr '\0' ' ' < "/proc/$pid/cmdline"
  else
    ps -p "$pid" -o args= 2>/dev/null || true
  fi
}

fluxkit_pid_alive() {
  local pid="$1"
  [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

fluxkit_is_flux_serve_process() {
  local pid="$1" repo_root="$2"
  local cmdline data_file
  fluxkit_pid_alive "$pid" || return 1
  cmdline="$(fluxkit_process_cmdline "$pid")"
  [[ "$cmdline" == *"serve"* ]] || return 1
  data_file="$(fluxkit_data_file)"
  [[ "$cmdline" == *"$data_file"* ]] || [[ "$cmdline" == *".flux/data.json"* ]] || [[ "$cmdline" == *"data.json"* ]]
}

fluxkit_ui_container_name() {
  local hash
  hash="$(fluxkit_sha256 "$(fluxkit_ui_seed)")"
  echo "fluxkit-${hash:0:12}"
}

fluxkit_is_fluxkit_container_name() {
  [[ "$1" =~ ^fluxkit-[0-9a-f]{12}$ ]]
}

fluxkit_is_docker_container_id() {
  [[ "$1" =~ ^[0-9a-fA-F]{12,64}$ ]]
}

fluxkit_docker_container_running() {
  local name="$1" docker_cmd
  [[ -n "$name" ]] || return 1
  docker_cmd="$(fluxkit_find_docker 2>/dev/null || return 1)"
  [[ "$("$docker_cmd" inspect -f '{{.State.Running}}' "$name" 2>/dev/null || echo false)" == "true" ]]
}

fluxkit_docker_container_managed() {
  local target="$1" docker_cmd
  [[ -n "$target" ]] || return 1
  docker_cmd="$(fluxkit_find_docker 2>/dev/null || return 1)"
  [[ "$("$docker_cmd" inspect -f '{{ index .Config.Labels "fluxkit.managed" }}' "$target" 2>/dev/null || true)" == "true" ]]
}

fluxkit_docker_fluxkit_container_targets() {
  local docker_cmd="$1" id name managed
  "$docker_cmd" ps --filter "label=fluxkit.managed=true" --format '{{.ID}}\t{{.Names}}\t{{.Label "fluxkit.managed"}}' 2>/dev/null |
    while IFS=$'\t' read -r id name managed; do
      [[ "$managed" == "true" ]] || continue
      fluxkit_is_fluxkit_container_name "$name" || continue
      [[ -n "$id" ]] || continue
      printf '%s\n' "$id"
    done
}

fluxkit_docker_fluxkit_container_rows() {
  local docker_cmd="$1"
  local id name ports managed mode scope branch repo data
  "$docker_cmd" ps --filter "label=fluxkit.managed=true" --format '{{.ID}}\t{{.Names}}\t{{.Ports}}\t{{.Label "fluxkit.managed"}}\t{{.Label "fluxkit.state_mode"}}\t{{.Label "fluxkit.external_scope"}}\t{{.Label "fluxkit.branch"}}\t{{.Label "fluxkit.repo_root"}}\t{{.Label "fluxkit.data_file"}}' 2>/dev/null |
    while IFS=$'\t' read -r id name ports managed mode scope branch repo data; do
      [[ "$managed" == "true" ]] || continue
      fluxkit_is_fluxkit_container_name "$name" || continue
      [[ -n "$id" ]] || continue
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$id" "$name" "${ports:-n/a}" "${mode:-unknown}" "${scope:-n/a}" "${branch:-n/a}" "${repo:-n/a}" "${data:-n/a}"
    done
}

fluxkit_stop_docker_ui_container() {
  local target="$1" docker_cmd
  fluxkit_is_fluxkit_container_name "$target" || fluxkit_is_docker_container_id "$target" || \
    fluxkit_die "invalid Fluxkit container: $target (use a CONTAINER value from 'fluxkit ui list')"
  docker_cmd="$(fluxkit_find_docker 2>/dev/null || fluxkit_die "docker not available")"
  fluxkit_docker_daemon_ready || fluxkit_die "Docker daemon not reachable (check: docker info)"
  fluxkit_docker_container_managed "$target" || fluxkit_die "container $target is not managed by Fluxkit"
  "$docker_cmd" rm -f "$target" >/dev/null || fluxkit_die "failed to stop container $target"
  fluxkit_info "stopped Flux UI (docker: $target)"
}

fluxkit_flux_cli_runnable() {
  local flux_cmd
  if [[ -n "${FLUXKIT_FLUX_CMD:-}" ]]; then
    echo "${FLUXKIT_FLUX_CMD}"
    return 0
  fi
  flux_cmd="$(fluxkit_find_flux_cli 2>/dev/null || return 1)"
  command -v bun >/dev/null 2>&1 || return 1
  echo "$flux_cmd"
}

fluxkit_ui_backend_available() {
  fluxkit_docker_daemon_ready
}

fluxkit_runtime_matches_repo() {
  local runtime_file="$1" repo_root="$2"
  local recorded_root=""
  [[ -f "$runtime_file" ]] || return 1
  recorded_root="$(grep -E '^FLUX_REPO_ROOT=' "$runtime_file" 2>/dev/null | head -1 | cut -d= -f2- || true)"
  [[ -n "$recorded_root" ]] && [[ "$recorded_root" == "$(fluxkit_canonical_path "$repo_root")" ]]
}

fluxkit_server_healthy() {
  local url="$1"
  command -v curl >/dev/null 2>&1 || return 1
  curl -sf --max-time 2 "${url%/}/api/projects" >/dev/null 2>&1
}

fluxkit_find_ui_port() {
  local preferred="$1" base span port i
  base="${FLUXKIT_PORT_BASE}"
  span="${FLUXKIT_PORT_SPAN}"
  local repo_root runtime_file
  repo_root="$(fluxkit_repo_root)"
  runtime_file="$(fluxkit_runtime_env)"

  # 1. Preferred port free
  if ! fluxkit_port_in_use "$preferred"; then
    echo "$preferred"
    return 0
  fi

  # 2. Preferred port serves this repo's Flux UI
  if fluxkit_runtime_matches_repo "$runtime_file" "$repo_root"; then
    FLUX_UI_PORT="$(fluxkit_runtime_get "$runtime_file" FLUX_UI_PORT)"
    FLUX_UI_BACKEND="$(fluxkit_runtime_get "$runtime_file" FLUX_UI_BACKEND)"
    FLUX_UI_CONTAINER="$(fluxkit_runtime_get "$runtime_file" FLUX_UI_CONTAINER)"
    FLUX_UI_PID="$(fluxkit_runtime_get "$runtime_file" FLUX_UI_PID)"
    if [[ "${FLUX_UI_PORT:-}" == "$preferred" ]]; then
      if [[ "${FLUX_UI_BACKEND:-cli}" == "docker" ]]; then
        if fluxkit_docker_container_running "${FLUX_UI_CONTAINER:-}"; then
          echo "$preferred"
          return 0
        fi
      elif fluxkit_pid_alive "${FLUX_UI_PID:-}" && fluxkit_is_flux_serve_process "${FLUX_UI_PID}" "$repo_root"; then
        echo "$preferred"
        return 0
      fi
    fi
  fi
  if fluxkit_server_healthy "http://127.0.0.1:${preferred}"; then
    if fluxkit_runtime_matches_repo "$runtime_file" "$repo_root"; then
      echo "$preferred"
      return 0
    fi
  fi

  # 3. Probe preferred+1 .. end of range, then wrap from base .. preferred-1
  for ((i = 1; i < span; i++)); do
    port=$((preferred + i))
    if (( port >= base + span )); then
      port=$((base + (port - base - span)))
    fi
    if ! fluxkit_port_in_use "$port"; then
      echo "$port"
      return 0
    fi
  done

  fluxkit_die "no free port found in range ${base}-$((base + span - 1))"
}

fluxkit_find_flux_cli() {
  if [[ -n "${FLUXKIT_FLUX_CMD:-}" ]]; then
    echo "$FLUXKIT_FLUX_CMD"
    return 0
  fi
  if command -v flux >/dev/null 2>&1; then
    command -v flux
    return 0
  fi
  return 1
}

fluxkit_find_docker() {
  if [[ -n "${FLUXKIT_DOCKER_CMD:-}" ]]; then
    echo "$FLUXKIT_DOCKER_CMD"
    return 0
  fi
  if command -v docker >/dev/null 2>&1; then
    command -v docker
    return 0
  fi
  return 1
}

fluxkit_docker_daemon_ready() {
  local docker_cmd
  docker_cmd="$(fluxkit_find_docker 2>/dev/null || return 1)"
  "$docker_cmd" info >/dev/null 2>&1
}

fluxkit_has_flux_backend() {
  fluxkit_ui_backend_available
}

# ---------------------------------------------------------------------------
# AGENTS.md managed block
# ---------------------------------------------------------------------------

fluxkit_agents_managed_content() {
  cat <<'EOF'
<!-- BEGIN FLUXKIT MANAGED BLOCK -->
## Flux task workflow

This repository uses Flux as the source of truth for task tracking.

### Required startup

1. Use the repository-local Flux MCP server to inspect and update the board.
2. Discover and confirm the active Flux project through MCP before starting implementation work.
3. List ready or in-progress tasks before choosing work.

Never invent a project ID. Never work against a Flux board from another repository.

### Flux access rules

- Use the repository-local Flux MCP server for all task reads and writes.
- Do not read or edit `.flux/data.json` or `.flux/project.json` directly.
- Do not treat files under `.flux/` as hand-edited config or board sources.
- The MCP server (or Flux CLI when run by a human) is the supported interface to Flux data.
- Use the repository-local Flux UI/API when you need to inspect the board in a browser.

### Task rules

- Tie every meaningful code change to a Flux task.
- Before starting implementation, make sure the task is represented on the Flux board.
- Keep task status current as work progresses.
- Add concise notes for important decisions, blockers, and verification results.
- When work is complete, run the relevant checks and record what was tested.
- If blocked, record the blocker clearly instead of silently continuing unrelated work.
- Keep changes focused on the selected task.
- Do not mark work complete unless the implementation and verification are both done.

### Repository-local Flux

Board data is stored at `.flux/data.json`; project hints may exist in `.flux/project.json`.

Agents must interact with Flux through the repository-local MCP server (or the UI/API), not by reading or writing those files directly.
Do not use global Flux state for this repository.
<!-- END FLUXKIT MANAGED BLOCK -->
EOF
}

fluxkit_global_agents_managed_content() {
  cat <<'EOF'
<!-- BEGIN FLUXKIT GLOBAL MANAGED BLOCK -->
## Fluxkit work tracking

When working inside a git repository, run `fluxkit configured` before using ad
hoc task tracking.

If `fluxkit configured` exits successfully, use the reported MCP command for
Flux task reads and writes. For external setups this is `fluxkit mcp`; for
repo-local setups this may be `.flux/bin/mcp`. Do not read or edit Fluxkit
storage files directly. The storage may be repository-local or external to the
repository.

If `fluxkit configured` reports `configured: no` or exits non-zero, do not
invent a Flux project or task ID. Ask the user whether they want Fluxkit
initialized.
<!-- END FLUXKIT GLOBAL MANAGED BLOCK -->
EOF
}

fluxkit_update_agents_md() {
  local agents_file="$1"
  local begin_line end_line tmp
  begin_line="$(grep -Fn "$AGENTS_BEGIN" "$agents_file" 2>/dev/null | head -1 | cut -d: -f1 || true)"
  end_line="$(grep -Fn "$AGENTS_END" "$agents_file" 2>/dev/null | head -1 | cut -d: -f1 || true)"

  if [[ -z "$begin_line" && -z "$end_line" ]]; then
    if [[ ! -s "$agents_file" ]]; then
      fluxkit_agents_managed_content >"$agents_file"
    else
      printf '\n' >>"$agents_file"
      fluxkit_agents_managed_content >>"$agents_file"
    fi
    return 0
  fi

  if [[ -n "$begin_line" && -n "$end_line" ]]; then
    if (( begin_line >= end_line )); then
      fluxkit_die "AGENTS.md managed block markers are malformed (begin must precede end)"
    fi
    tmp="$(mktemp)"
    {
      if (( begin_line > 1 )); then
        head -n $((begin_line - 1)) "$agents_file"
      fi
      fluxkit_agents_managed_content
      tail -n +$((end_line + 1)) "$agents_file"
    } >"$tmp"
    mv "$tmp" "$agents_file"
    return 0
  fi

  fluxkit_die "AGENTS.md managed block markers are malformed (found only one of begin/end)"
}

fluxkit_update_home_agents_md() {
  local agents_file="$1"
  local begin_line end_line tmp
  begin_line="$(grep -Fn "$GLOBAL_AGENTS_BEGIN" "$agents_file" 2>/dev/null | head -1 | cut -d: -f1 || true)"
  end_line="$(grep -Fn "$GLOBAL_AGENTS_END" "$agents_file" 2>/dev/null | head -1 | cut -d: -f1 || true)"

  if [[ -z "$begin_line" && -z "$end_line" ]]; then
    mkdir -p "$(dirname "$agents_file")"
    if [[ ! -s "$agents_file" ]]; then
      fluxkit_global_agents_managed_content >"$agents_file"
    else
      printf '\n' >>"$agents_file"
      fluxkit_global_agents_managed_content >>"$agents_file"
    fi
    return 0
  fi

  if [[ -n "$begin_line" && -n "$end_line" ]]; then
    if (( begin_line >= end_line )); then
      fluxkit_die "$agents_file Fluxkit global managed block markers are malformed (begin must precede end)"
    fi
    tmp="$(mktemp)"
    {
      if (( begin_line > 1 )); then
        head -n $((begin_line - 1)) "$agents_file"
      fi
      fluxkit_global_agents_managed_content
      tail -n +$((end_line + 1)) "$agents_file"
    } >"$tmp"
    mv "$tmp" "$agents_file"
    return 0
  fi

  fluxkit_die "$agents_file Fluxkit global managed block markers are malformed (found only one of begin/end)"
}

fluxkit_agents_block_valid() {
  local agents_file="$1"
  [[ -f "$agents_file" ]] || return 1
  grep -Fq "$AGENTS_BEGIN" "$agents_file" && grep -Fq "$AGENTS_END" "$agents_file"
}

fluxkit_global_agents_block_valid() {
  local agents_file="$1"
  [[ -f "$agents_file" ]] || return 1
  grep -Fq "$GLOBAL_AGENTS_BEGIN" "$agents_file" && grep -Fq "$GLOBAL_AGENTS_END" "$agents_file"
}

# ---------------------------------------------------------------------------
# .gitignore
# ---------------------------------------------------------------------------

fluxkit_update_gitignore() {
  local root="$1"
  local gitignore="$root/.gitignore"
  local entries=(".flux/runtime.env" ".flux/ui.log" ".flux/*.pid")
  local entry

  if [[ ! -f "$gitignore" ]]; then
    : >"$gitignore"
  fi

  for entry in "${entries[@]}"; do
    if ! grep -Fxq "$entry" "$gitignore" 2>/dev/null; then
      if [[ -s "$gitignore" ]] && [[ -n "$(tail -c1 "$gitignore" 2>/dev/null || true)" ]]; then
        printf '\n' >>"$gitignore"
      fi
      printf '%s\n' "$entry" >>"$gitignore"
    fi
  done
}

fluxkit_gitignore_ignores_runtime() {
  local root="$1"
  local gitignore="$root/.gitignore"
  [[ -f "$gitignore" ]] && grep -Fxq ".flux/runtime.env" "$gitignore"
}

# ---------------------------------------------------------------------------
# Init helpers
# ---------------------------------------------------------------------------

fluxkit_backup_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  cp -p "$file" "${file}.bak.$(date +%Y%m%d%H%M%S)"
  fluxkit_warn "backed up $file before overwrite"
}

fluxkit_write_json_if_missing() {
  local file="$1" content="$2"
  if [[ ! -f "$file" ]]; then
    mkdir -p "$(dirname "$file")"
    printf '%s\n' "$content" >"$file"
  fi
}

fluxkit_write_file_if_missing() {
  local file="$1"
  shift
  if [[ ! -f "$file" ]]; then
    mkdir -p "$(dirname "$file")"
    cat >"$file"
  fi
}

fluxkit_generate_mcp_launcher() {
  local repo_root="$1"
  local flux_dir="$2"
  local mcp_script="$flux_dir/bin/mcp"
  mkdir -p "$(dirname "$mcp_script")"
  cat >"$mcp_script" <<LAUNCHER
#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="\$(cd "\$(dirname "\${BASH_SOURCE[0]}")" && pwd)"
FLUX_DIR="\$(cd "\$SCRIPT_DIR/.." && pwd)"
REPO_ROOT="\$(cd "\$FLUX_DIR/.." && pwd)"
RUNTIME_ENV="\$FLUX_DIR/runtime.env"
DATA_FILE="\$FLUX_DIR/data.json"
FLUX_DOCKER_IMAGE="$FLUX_DOCKER_IMAGE"

runtime_get() {
  local file="\$1" key="\$2" line
  [[ -f "\$file" ]] || return 0
  line="\$(grep -E "^\${key}=" "\$file" 2>/dev/null | head -1 || true)"
  printf '%s' "\${line#*=}"
}

run_mcp_docker() {
  local docker_cmd mode="\$1"
  shift
  docker_cmd="\$(command -v docker 2>/dev/null || true)"
  [[ -n "\$docker_cmd" ]] || {
    echo "flux-mcp: docker required for MCP (image: \$FLUX_DOCKER_IMAGE)" >&2
    echo "flux-mcp: run: fluxkit ui up  (starts UI + enables remote MCP mode)" >&2
    exit 1
  }
  if ! "\$docker_cmd" info >/dev/null 2>&1; then
    echo "flux-mcp: docker daemon not reachable (check: docker info)" >&2
    exit 1
  fi
  if [[ "\$mode" == "remote" ]]; then
    exec "\$docker_cmd" run -i --rm \
      --network host \
      -e "FLUX_SERVER=\$FLUX_SERVER" \
      "\$FLUX_DOCKER_IMAGE" \
      bun /app/packages/mcp/dist/index.js
  fi
  exec "\$docker_cmd" run -i --rm \
    --user "\$(id -u):\$(id -g)" \
    -v "\$REPO_ROOT:\$REPO_ROOT" \
    -e "FLUX_DIR=\$FLUX_DIR" \
    -e "FLUX_DATA=\$DATA_FILE" \
    "\$FLUX_DOCKER_IMAGE" \
    bun /app/packages/mcp/dist/index.js
}

if [[ -f "\$RUNTIME_ENV" ]]; then
  FLUX_SERVER="\$(runtime_get "\$RUNTIME_ENV" FLUX_SERVER)"
  if [[ -n "\${FLUX_SERVER:-}" ]]; then
    if command -v curl >/dev/null 2>&1 && curl -sf --max-time 2 "\${FLUX_SERVER%/}/api/projects" >/dev/null 2>&1; then
      export FLUX_SERVER
      unset FLUX_DATA FLUX_DIR
      run_mcp_docker remote
    fi
  fi
fi

cd "\$REPO_ROOT"
export FLUX_DIR="\$FLUX_DIR"
export FLUX_DATA="\$DATA_FILE"
unset FLUX_SERVER
run_mcp_docker local
LAUNCHER
  chmod +x "$mcp_script"
}

fluxkit_write_cursor_mcp() {
  local cursor_dir="$1"
  local mcp_json="$cursor_dir/mcp.json"
  mkdir -p "$cursor_dir"

  if [[ ! -f "$mcp_json" ]]; then
    cat >"$mcp_json" <<'EOF'
{
  "mcpServers": {
    "flux": {
      "type": "stdio",
      "command": ".flux/bin/mcp"
    }
  }
}
EOF
    return 0
  fi

  if grep -q '"flux"' "$mcp_json" 2>/dev/null; then
    if command -v python3 >/dev/null 2>&1; then
      python3 - "$mcp_json" <<'PY'
import json, sys
path = sys.argv[1]
legacy = "${workspaceFolder}/.flux/bin/mcp"
with open(path) as f:
    data = json.load(f)
flux = data.get("mcpServers", {}).get("flux")
if isinstance(flux, dict) and flux.get("command") == legacy:
    flux["command"] = ".flux/bin/mcp"
    with open(path, "w") as f:
        json.dump(data, f, indent=2)
        f.write("\n")
PY
    fi
    return 0
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$mcp_json" <<'PY'
import json, sys
path = sys.argv[1]
with open(path) as f:
    data = json.load(f)
data.setdefault("mcpServers", {})["flux"] = {
    "type": "stdio",
    "command": ".flux/bin/mcp",
}
with open(path, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PY
    return 0
  fi

  fluxkit_warn ".cursor/mcp.json exists without a flux entry; add manually or install python3 for auto-merge"
}

fluxkit_write_codex_config() {
  local codex_dir="$1"
  local config_toml="$codex_dir/config.toml"
  mkdir -p "$codex_dir"

  if [[ ! -f "$config_toml" ]]; then
    cat >"$config_toml" <<'EOF'
[mcp_servers.flux]
command = ".flux/bin/mcp"
startup_timeout_sec = 20
tool_timeout_sec = 120
EOF
  elif ! grep -q '\[mcp_servers\.flux\]' "$config_toml" 2>/dev/null; then
    cat >>"$config_toml" <<'EOF'

[mcp_servers.flux]
command = ".flux/bin/mcp"
startup_timeout_sec = 20
tool_timeout_sec = 120
EOF
  fi
}

fluxkit_global_mcp_command() {
  local found source_path
  source_path="${BASH_SOURCE[0]}"
  if [[ "$source_path" == */* && "$source_path" != /* ]]; then
    source_path="$(pwd)/$source_path"
  fi
  if [[ "$source_path" == /* && -x "$source_path" ]]; then
    fluxkit_canonical_path "$source_path"
    return 0
  fi

  found="$(command -v fluxkit 2>/dev/null || true)"
  if [[ -n "$found" ]]; then
    echo "$found"
    return 0
  fi

  fluxkit_die "cannot locate fluxkit command for global MCP config"
}

fluxkit_global_codex_config_file() {
  echo "${CODEX_HOME:-$(fluxkit_home_dir)/.codex}/config.toml"
}

fluxkit_global_cursor_mcp_file() {
  echo "$(fluxkit_home_dir)/.cursor/mcp.json"
}

fluxkit_home_agents_file() {
  echo "$(fluxkit_home_dir)/AGENTS.md"
}

fluxkit_write_global_codex_config() {
  local config_toml command_json
  config_toml="$(fluxkit_global_codex_config_file)"
  command_json="$(fluxkit_json_quote "$(fluxkit_global_mcp_command)")"
  mkdir -p "$(dirname "$config_toml")"

  if [[ ! -f "$config_toml" ]]; then
    cat >"$config_toml" <<EOF
[mcp_servers.flux]
command = ${command_json}
args = ["mcp"]
startup_timeout_sec = 20
tool_timeout_sec = 120
EOF
  elif ! grep -q '\[mcp_servers\.flux\]' "$config_toml" 2>/dev/null; then
    cat >>"$config_toml" <<EOF

[mcp_servers.flux]
command = ${command_json}
args = ["mcp"]
startup_timeout_sec = 20
tool_timeout_sec = 120
EOF
  elif command -v python3 >/dev/null 2>&1; then
    python3 - "$config_toml" "$command_json" <<'PY'
import re, sys
path, command_json = sys.argv[1], sys.argv[2]
block = f"""[mcp_servers.flux]
command = {command_json}
args = ["mcp"]
startup_timeout_sec = 20
tool_timeout_sec = 120
"""
with open(path) as f:
    text = f.read()
pattern = r"(?ms)^\[mcp_servers\.flux\]\n.*?(?=^\[|\Z)"
text = re.sub(pattern, block, text, count=1)
with open(path, "w") as f:
    f.write(text)
    if text and not text.endswith("\n"):
        f.write("\n")
PY
  else
    fluxkit_warn "$config_toml already contains [mcp_servers.flux]; leaving it unchanged because python3 is unavailable"
  fi
}

fluxkit_write_global_cursor_mcp() {
  local mcp_json command
  mcp_json="$(fluxkit_global_cursor_mcp_file)"
  command="$(fluxkit_global_mcp_command)"
  mkdir -p "$(dirname "$mcp_json")"

  if [[ ! -f "$mcp_json" ]]; then
    cat >"$mcp_json" <<EOF
{
  "mcpServers": {
    "flux": {
      "type": "stdio",
      "command": $(fluxkit_json_quote "$command"),
      "args": ["mcp"]
    }
  }
}
EOF
    return 0
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$mcp_json" "$command" <<'PY'
import json, sys
path, command = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = json.load(f)
data.setdefault("mcpServers", {})["flux"] = {
    "type": "stdio",
    "command": command,
    "args": ["mcp"],
}
with open(path, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PY
    return 0
  fi

  if grep -q '"flux"' "$mcp_json" 2>/dev/null; then
    fluxkit_warn "$mcp_json already contains a flux entry; leaving it unchanged because python3 is unavailable"
  else
    fluxkit_warn "$mcp_json exists; add the fluxkit mcp entry manually or install python3 for auto-merge"
  fi
}

fluxkit_write_global_integrations() {
  fluxkit_write_global_codex_config
  fluxkit_write_global_cursor_mcp
  fluxkit_update_home_agents_md "$(fluxkit_home_agents_file)"
}

fluxkit_global_codex_configured() {
