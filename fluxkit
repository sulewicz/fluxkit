# MCP command
# ---------------------------------------------------------------------------

fluxkit_run_mcp_docker() {
  local mode="$1" docker_cmd repo_root flux_dir data_file
  local volume_args=()
  shift || true

  docker_cmd="$(fluxkit_find_docker 2>/dev/null || true)"
  [[ -n "$docker_cmd" ]] || {
    echo "flux-mcp: docker required for MCP (image: $FLUX_DOCKER_IMAGE)" >&2
    echo "flux-mcp: run: fluxkit ui up  (starts UI + enables remote MCP mode)" >&2
    exit 1
  }
  if ! "$docker_cmd" info >/dev/null 2>&1; then
    echo "flux-mcp: docker daemon not reachable (check: docker info)" >&2
    exit 1
  fi

  if [[ "$mode" == "remote" ]]; then
    exec "$docker_cmd" run -i --rm \
      --network host \
      -e "FLUX_SERVER=$FLUX_SERVER" \
      "$FLUX_DOCKER_IMAGE" \
      bun /app/packages/mcp/dist/index.js
  fi

  repo_root="$(fluxkit_repo_root)"
  flux_dir="$(fluxkit_flux_dir)"
  data_file="$(fluxkit_data_file)"

  volume_args=(-v "${repo_root}:${repo_root}")
  if ! fluxkit_path_is_inside "$flux_dir" "$repo_root"; then
    volume_args+=(-v "${flux_dir}:${flux_dir}")
  fi

  exec "$docker_cmd" run -i --rm \
    --user "$(id -u):$(id -g)" \
    "${volume_args[@]}" \
    -e "FLUX_DIR=${flux_dir}" \
    -e "FLUX_DATA=${data_file}" \
    "$FLUX_DOCKER_IMAGE" \
    bun /app/packages/mcp/dist/index.js
}

fluxkit_cmd_mcp() {
  local runtime_file data_file
  fluxkit_require_git
  data_file="$(fluxkit_data_file)"
  [[ -f "$data_file" ]] || fluxkit_die "Fluxkit is not initialized for this repo/branch; run: fluxkit init --external"

  runtime_file="$(fluxkit_runtime_env)"
  if [[ -f "$runtime_file" ]] && fluxkit_runtime_matches_repo "$runtime_file" "$(fluxkit_repo_root)"; then
    FLUX_SERVER="$(fluxkit_runtime_get "$runtime_file" FLUX_SERVER)"
    if [[ -n "${FLUX_SERVER:-}" ]] && fluxkit_server_healthy "$FLUX_SERVER"; then
      export FLUX_SERVER
      unset FLUX_DATA FLUX_DIR
      fluxkit_run_mcp_docker remote
    fi
  fi

  export FLUX_DIR="$(fluxkit_flux_dir)"
  export FLUX_DATA="$data_file"
  unset FLUX_SERVER
  fluxkit_run_mcp_docker local
}

# ---------------------------------------------------------------------------
# Configuration status
# ---------------------------------------------------------------------------

fluxkit_cmd_configured() {
  local quiet=0 root mode scope flux_dir data_file config_file mcp

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -q|--quiet)
        quiet=1
        ;;
      *)
        fluxkit_die "unknown configured option: $1 (use --quiet or no options)"
        ;;
    esac
    shift
  done

  root="$(fluxkit_repo_root 2>/dev/null || true)"
  if [[ -z "$root" ]]; then
    (( quiet )) || {
      echo "configured: no"
      echo "reason: not inside a git repository"
    }
    return 1
  fi

  if fluxkit_local_configured; then
    FLUXKIT_STATE_MODE=local
    mode="local"
    scope="n/a"
    flux_dir="$(fluxkit_local_flux_dir)"
    mcp=".flux/bin/mcp"
  elif fluxkit_external_configured; then
    FLUXKIT_STATE_MODE=external
    mode="external"
    scope="$(fluxkit_external_scope)"
    flux_dir="$(fluxkit_external_flux_dir)"
    mcp="fluxkit mcp"
  else
    (( quiet )) || {
      echo "configured: no"
      echo "repo root: $root"
      echo "fix: fluxkit init  OR  fluxkit init --external"
    }
    return 1
  fi

  data_file="$flux_dir/data.json"
  config_file="$flux_dir/config.json"
  (( quiet )) && return 0

  echo "configured: yes"
  echo "repo root: $root"
  echo "mode: $mode"
  echo "scope: $scope"
  if [[ "$mode" == "external" && "$scope" == "branch" ]]; then
    echo "branch: $(fluxkit_branch_name)"
  fi
  echo "config: $config_file"
  echo "data: $data_file"
  echo "mcp: $mcp"
}

